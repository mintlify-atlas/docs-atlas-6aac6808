  "keyFeatures": [
    "High-level Node API with topic-based publish/subscribe streams",
    "Local-first, offline-first data synchronisation over QUIC/iroh",
    "Single-writer append-only CRDT operation logs with fork resistance",
    "Decentralised group encryption with post-compromise security and forward secrecy",
    "Fine-grained, per-member access control with DAG-based group management",
    "Transport-agnostic design supporting Internet, BLE, LoRa, and packet radio",
    "At-least-once event delivery with crash recovery and replay",
    "Confidential topic and node discovery protocol",
    "Large file (blob) transfer with content-addressing"
  ],
  "publicApiSurface": [
    "p2panda::spawn()",
    "p2panda::builder() -> NodeBuilder",
    "Node::stream<M>(topic) -> (StreamPublisher<M>, StreamSubscription<M>)",
    "Node::ephemeral_stream<M>(topic) -> (EphemeralStreamPublisher<M>, EphemeralStreamSubscription<M>)",
    "Node::event_stream() -> Stream<SystemEvent>",
    "Node::insert_bootstrap(node_id, relay_url)",
    "NodeBuilder::signing_key(key)",
    "NodeBuilder::database_url(url)",
    "NodeBuilder::relay_url(url)",
    "NodeBuilder::bootstrap(node_id, relay_url)",
    "NodeBuilder::network_id(id)",
    "NodeBuilder::ack_policy(policy)",
    "StreamPublisher::publish(message)",
    "Topic::random()",
    "SigningKey::generate()",
    "Header { version, verifying_key, signature, payload_size, payload_hash, timestamp, seq_num, backlink, extensions }",
    "Body::new(bytes)",
    "Operation",
    "Hash",
    "Cursor",
    "p2panda_core::validate_operation()",
    "p2panda_core::validate_backlink()",
    "p2panda_core::validate_header()"
  ]
